#!/opt/venv-attestation/bin/python3
"""
ee-gpu-evidence — collect raw NVIDIA H100 confidential-compute
attestation evidence and emit it to stdout in easyenclave's
length-prefixed wire format. Invoked by PID 1's `attest` socket
method via the helper-script seam in src/attestation/nvgpu.rs.

Wire format (consumed by HelperBackend in nvgpu.rs):

    gpu_report_len:    u32, big-endian
    gpu_report:        <gpu_report_len> raw bytes (signed GPU report)
    switch_report_len: u32, big-endian (0 if no NVL/NVSwitch fabric)
    switch_report:     <switch_report_len> raw bytes (signed switch report)

Exit code: 0 on success, anything else captured into the response's
`evidence.nvgpu_error`. Failure here MUST NOT escalate to a top-level
attest failure — easyenclave's invariant is "evidence producer, not
verifier" (see docs/gpu-attestation.md).

Optional verifier nonce on stdin (one hex line). Today the runtime
writes nothing on stdin; this is reserved for the eventual nonce-
based combined-evidence binding (see docs/gpu-attestation.md "Open
spec questions").
"""
import os
import struct
import sys


def emit_frame(gpu_report: bytes, switch_report: bytes = b"") -> None:
    """Write the length-prefixed wire frame to stdout."""
    out = sys.stdout.buffer
    out.write(struct.pack(">I", len(gpu_report)))
    out.write(gpu_report)
    out.write(struct.pack(">I", len(switch_report)))
    out.write(switch_report)
    out.flush()


def read_optional_nonce() -> str:
    """Read a one-line hex nonce from stdin if present, else "0"*64."""
    if sys.stdin.isatty():
        return "0" * 64
    line = sys.stdin.readline().strip()
    return line or "0" * 64


def main() -> int:
    nonce = read_optional_nonce()

    try:
        # nv-attestation-sdk's flow: build an Attestation, configure
        # the local GPU verifier, call attest(), pull out the raw
        # evidence. Exact API surface tracks nv-attestation-sdk
        # 2.6.x — bump pins in mkosi.profiles/llm-cuda/mkosi.postinst.
        # chroot if NVIDIA breaks compatibility.
        from nv_attestation_sdk import attestation

        client = attestation.Attestation()
        client.set_name("easyenclave")
        client.set_nonce(nonce)
        client.add_verifier(
            attestation.Devices.GPU,
            attestation.Environment.LOCAL,
            "",  # claims_version (unused for LOCAL)
            "",  # ocsp_nonce (unused for LOCAL)
        )
        client.attest()

        # The evidence list is what gets packaged for ITA. Each entry
        # is a (claims, evidence) tuple per the SDK; we want the raw
        # GPU report bytes from the GPU verifier's evidence blob.
        evidence_list = client.get_evidence()
        gpu_report = b""
        for entry in evidence_list:
            # Entry shape varies by SDK version — try common keys.
            if isinstance(entry, dict):
                blob = (
                    entry.get("evidence")
                    or entry.get("gpu_attestation_report")
                    or entry.get("attestationReport")
                )
                if blob:
                    if isinstance(blob, str):
                        # Hex-encoded report — decode.
                        gpu_report = bytes.fromhex(blob)
                    elif isinstance(blob, (bytes, bytearray)):
                        gpu_report = bytes(blob)
                    break
            elif isinstance(entry, (bytes, bytearray)):
                gpu_report = bytes(entry)
                break

        if not gpu_report:
            print(
                "ee-gpu-evidence: no GPU evidence in nv-attestation-sdk output",
                file=sys.stderr,
            )
            return 1

        # Switch report only meaningful on NVL/NVSwitch hosts. For
        # single-GPU hosts emit length 0 — easyenclave's parser
        # treats empty switch_report as "absent" and omits the field
        # from the response.
        switch_report = b""
        # TODO: pull switch_report from a nv_attestation_sdk
        # NVSwitch verifier when running on multi-GPU hosts. The
        # plumbing is the same shape: add_verifier(NVSwitch,
        # LOCAL, ...), then pick the second evidence entry.

        emit_frame(gpu_report, switch_report)
        return 0

    except ImportError as e:
        print(
            f"ee-gpu-evidence: nv-attestation-sdk import failed: {e}",
            file=sys.stderr,
        )
        return 1
    except Exception as e:
        print(f"ee-gpu-evidence: collection failed: {e}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    sys.exit(main())
