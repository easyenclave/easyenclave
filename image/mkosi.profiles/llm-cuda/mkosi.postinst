#!/bin/bash
# Profile-specific post-install: create Python venvs for vLLM and the
# nv-attestation-sdk that backs ee-gpu-evidence.
#
# Runs OUTSIDE the chroot (mkosi.postinst, not .chroot). pip needs
# DNS to reach pypi.org, which mkosi's chroot sandboxes off; the
# workaround (cribbed from ConferLabs/confer-image's mkosi.postinst)
# is to copy the host's /etc/resolv.conf into /buildroot, then
# `chroot /buildroot ...` for the pip install itself.
#
# Reproducibility: relies on the base mkosi.conf's `SourceDateEpoch=0`
# (which sets SOURCE_DATE_EPOCH in the build env, respected by pip
# and setuptools for wheel metadata timestamps) plus mkosi's finalize
# step "Normalizing modification times of /" which clamps every file
# mtime in the rootfs to SOURCE_DATE_EPOCH before squashfs is built.
# confer-image's mkosi.conf installs faketime as a package but never
# actually invokes it in any build script — same posture here.
set -euo pipefail

# DNS into the chroot. mkosi's tools sandbox has a different
# /etc/resolv.conf (or none) than the host, so copying that one
# isn't reliable — hardcode public DNS instead. The base
# mkosi.postinst.chroot symlinks /etc/resolv.conf -> /run/resolv.conf
# for runtime, and our cleanup at the end of this script removes
# the build-time file so the runtime symlink takes over cleanly.
mkdir -p /buildroot/etc /buildroot/run
rm -f /buildroot/etc/resolv.conf
cat > /buildroot/etc/resolv.conf <<DNSEOF
nameserver 1.1.1.1
nameserver 8.8.8.8
DNSEOF

# vLLM venv. The bulk of the rootfs (~5 GB after install). Use
# --no-cache-dir so pip's wheel cache doesn't land in the rootfs.
echo "[llm-cuda postinst] creating /opt/venv-vllm"
chroot /buildroot python3 -m venv /opt/venv-vllm
chroot /buildroot /opt/venv-vllm/bin/pip install --upgrade --no-cache-dir pip
chroot /buildroot /opt/venv-vllm/bin/pip install --no-cache-dir vllm==0.17.0

# nv-attestation-sdk venv (separate because nv-ppcie-verifier's
# pinned deps conflict with vLLM's modern set — same split confer-
# image uses).
echo "[llm-cuda postinst] creating /opt/venv-attestation"
chroot /buildroot python3 -m venv /opt/venv-attestation
chroot /buildroot /opt/venv-attestation/bin/pip install --upgrade --no-cache-dir pip
chroot /buildroot /opt/venv-attestation/bin/pip install --no-cache-dir \
    nv-attestation-sdk==2.6.3 \
    nv-local-gpu-verifier==2.6.3 \
    nv-ppcie-verifier==1.6.4

# Pre-compile bytecode with hash-based invalidation. First-import on
# the read-only verity-protected rootfs would otherwise try to write
# .pyc and fail.
echo "[llm-cuda postinst] pre-compiling bytecode"
chroot /buildroot python3 -m compileall -q --invalidation-mode=unchecked-hash \
    /opt/venv-vllm /opt/venv-attestation || true

# Drop pip caches that landed despite --no-cache-dir, and clean up
# the temporary resolv.conf we wrote in (the base postinst.chroot
# will re-establish the runtime symlink to /run/resolv.conf).
rm -rf /buildroot/root/.cache/pip /buildroot/tmp/pip-* 2>/dev/null || true
rm -f /buildroot/etc/resolv.conf

echo "[llm-cuda postinst] done."
