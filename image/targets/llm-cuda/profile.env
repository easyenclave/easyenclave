# LLM (vLLM + CUDA) target — TDX confidential VM with NVIDIA GPU passthrough.
#
# Pattern adapted from ConferLabs/confer-image. confer-image runs vLLM as a
# systemd unit; EasyEnclave's invariant is "no systemd, easyenclave is PID 1,
# workloads are bare commands" — so each of confer-image's services
# (nvidia-persistenced, nvidia-fabricmanager, nvidia-cc-attestation,
# vllm) maps to a `boot_workloads` entry in /etc/easyenclave/config.json.
# See image/mkosi.profiles/llm-cuda/mkosi.extra/etc/easyenclave/config.json
# for the baked-in sample.
#
# Boot chain: UEFI → UKI → kernel + initrd → qemu vendor stage (config from
# /agent.env on a secondary disk) → switch_root → easyenclave (PID 1) →
# nvidia-persistenced → nvidia-fabricmanager → vllm-serve.
#
# This target intentionally uses the qemu vendor stage. H100 TDX is most often
# bare-metal or on-prem; switch TARGET_VENDOR to gcp/azure to reuse those
# metadata flows when running on a public cloud GPU TDX instance.
#
# SCAFFOLDING NOTE: this profile sets up the skeleton (target, mkosi profile,
# vllm-serve launcher, sample boot_workloads). The actual NVIDIA driver +
# CUDA + vLLM package bake is intentionally deferred — see
# image/mkosi.profiles/llm-cuda/mkosi.conf TODO and the README followup
# callout. A `make build TARGET=llm-cuda` today produces a bootable image
# without GPU support; treat it as a smoke target until the driver bake
# lands.

TARGET_FORMAT=disk
TARGET_ROOT_STRATEGY=ext4-label
TARGET_VENDOR=qemu

# IOMMU on (intel + amd flags both — the kernel ignores the inapplicable one)
# enables VFIO/GPU passthrough. pcie_acs_override matches confer-image and
# helps with certain consumer-grade hardware passthrough setups; safe on
# server NICs/GPUs.
TARGET_CMDLINE="root=LABEL=root console=ttyS0,115200 intel_iommu=on amd_iommu=on iommu=pt"

# Modules: TDX guest + tsm-report (attestation), virtio (storage/net),
# isofs (config disk), nvme (typical GPU host root). NVIDIA drivers do NOT
# go in the initrd — they're DKMS-built into the rootfs and loaded after
# switch_root by the boot_workloads sequence.
TARGET_INITRD_MODULES="dm-verity nvme tdx-guest tsm-report virtio_net virtio_blk virtio_pci virtio_scsi isofs"

TARGET_OUTPUTS="efi raw qcow2"

# When the mkosi.profiles/<name>/ tree exists, the Makefile passes
# --profile=<name> to mkosi so target-specific package overlays apply.
TARGET_MKOSI_PROFILE=llm-cuda

# This target uses the kernel installed *into the rootfs* (Ubuntu's
# linux-generic-hwe-24.04) instead of the host's kernel that the other
# targets borrow via `cp /boot/vmlinuz-$(uname -r)`. Reasons:
#   1. NVIDIA driver bake (next step) needs DKMS to build kernel modules
#      against a kernel package whose headers also live in the rootfs.
#   2. Reproducibility: the rootfs hash is independent of the build
#      host's kernel version, so `make build TARGET=llm-cuda` is
#      stable across machines (matches confer-image's posture).
#
# When this is `yes`, the Makefile resolves KVER from
# $(ROOTFS_DIR)/lib/modules/<single-entry>/ post-mkosi-build, copies the
# kernel from $(ROOTFS_DIR)/boot/vmlinuz-$KVER, and points mkinitrd.sh
# at the rootfs module tree via EE_MOD_SRC.
TARGET_USE_PACKAGED_KERNEL=yes

# H100/H200 TDX hosts typically have plenty of memory; tune to taste.
# Informational only — the launching VMM picks the real values, which
# influence MRTD.
TARGET_DEFAULT_MEM=80G
TARGET_DEFAULT_VCPU=16
