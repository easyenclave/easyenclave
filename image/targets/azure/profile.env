# Azure TDX CVM target — sealed GPT disk exported as a VHD.
#
# Boot chain: UEFI (Azure TDVF) → ESP/EFI/BOOT/BOOTX64.EFI (UKI) →
# kernel + our initrd → findfs LABEL=root → mount ext4 → vendor stage
# (azure: hv_netvsc/DHCP/IMDS customData) → switch_root.
#
# Azure CVMs use Hyper-V VMBus paravirt (hv_vmbus / hv_netvsc /
# hv_storvsc), not virtio. Keep virtio_* as a fallback so the same
# image still boots on plain Azure Gen2 hardware without VMBus.
#
# Attestation is still Intel TDX via configfs-tsm — unchanged from gcp.
# MRTD/RTMR will differ from gcp (different TDVF, different UKI) and
# from any other Azure machine type (MRTD depends on memory + vCPU).

TARGET_FORMAT=disk
TARGET_ROOT_STRATEGY=ext4-label
TARGET_VENDOR=azure
TARGET_CMDLINE="root=LABEL=root console=ttyS0,115200"

# Hyper-V drivers (vmbus/net/storage) + generic fallbacks. The azure
# vendor stage modprobes hv_* first; if a newer Azure SKU exposes
# virtio devices those still load too.
TARGET_INITRD_MODULES="dm-verity tdx-guest tsm-report hv_vmbus hv_netvsc hv_storvsc virtio_net virtio_blk virtio_pci virtio_scsi"

# Azure expects a fixed-size VHD (not dynamic) with size aligned to 1 MB.
# `vhd` output triggers a qemu-img convert -O vpc subformat=fixed in
# mkimage.sh. `raw` is kept so the same disk can be booted locally for
# debugging without re-importing from VHD.
TARGET_OUTPUTS="efi raw vhd"

TARGET_DEFAULT_MEM=4G
TARGET_DEFAULT_VCPU=2
